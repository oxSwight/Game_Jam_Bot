BOT_TOKEN=your_telegram_bot_token
ADMIN_IDS=123456789,987654321

# The closed group the bot gates. On approval the bot mints a personal
# join-request invite link into this chat and auto-approves only the approved
# applicant, so the bot MUST be an admin there with "invite users" / "add
# members" permission. Use the numeric chat id (e.g. -1001234567890).
GROUP_CHAT_ID=-1001234567890

# Hard ceiling on applications in the pending queue. /register is refused when it
# is reached, to blunt sign-up floods.
PENDING_CAP=300

# Password for the compose-managed PostgreSQL. REQUIRED for docker compose —
# there is no default; pick a long random value (e.g. `openssl rand -hex 24`).
POSTGRES_PASSWORD=change-me-to-a-long-random-value

# PostgreSQL is required in production. For local (non-compose) runs point it at
# your own instance; docker-compose.yml overrides it using POSTGRES_PASSWORD.
DATABASE_URL=postgresql+asyncpg://gamejam:change-me-to-a-long-random-value@localhost:5432/gamejam

REDIS_URL=redis://localhost:6379/0

LOG_LEVEL=INFO
LOG_JSON=false
