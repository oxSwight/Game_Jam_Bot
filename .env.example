BOT_TOKEN=your_telegram_bot_token
ADMIN_IDS=123456789,987654321

# The closed group the bot gates. On approval the bot mints a single-use invite
# link into this chat, so the bot MUST be an admin there with "invite users" /
# "add members" permission. Use the numeric chat id (e.g. -1001234567890).
GROUP_CHAT_ID=-1001234567890

# Hard ceiling on applications in the pending queue. /register is refused when it
# is reached, to blunt sign-up floods.
PENDING_CAP=300

# PostgreSQL is required in production.
DATABASE_URL=postgresql+asyncpg://gamejam:gamejam@localhost:5432/gamejam

REDIS_URL=redis://localhost:6379/0

LOG_LEVEL=INFO
LOG_JSON=false
